PANGRAM
 INPUT.SENTENCE = REPLACE(INPUT.SENTENCE, &LCASE, &UCASE)
CLEAN   INPUT.SENTENCE NOTANY(&UCASE) = :S(CLEAN)
 UPPER.LETTERS = &UCASE
FOUND   UPPER.LETTERS ANY(INPUT.SENTENCE) = :S(FOUND)
 IDENT(UPPER.LETTERS) :S(IS.PANGRAM)F(NOT.PANGRAM)
IS.PANGRAM RESULT = 1 :(DONE)
NOT.PANGRAM RESULT = 0 :(DONE)
DONE
END